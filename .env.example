# Email Configuration (Required for Email Notifications)
# For Gmail: Use your email address and an App Password (not your regular password)
# Get App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Frontend URL (for email links)
FRONTEND_URL=https://admin-desk-frontend.netlify.app

# Optional: For production, use SendGrid or Resend instead of Gmail
# Remove Gmail config above and use:
# SENDGRID_API_KEY=your-sendgrid-api-key
# or
# RESEND_API_KEY=your-resend-api-key
